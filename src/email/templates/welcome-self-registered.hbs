<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f0f0f0;">
  <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff;">
    {{> header}}

    <div style="padding: 32px 24px;">
      <h2 style="color: #333333; margin: 0 0 16px 0;">Welcome to the Gym!</h2>
      <p style="color: #555555; line-height: 1.6; margin: 0 0 8px 0;">Hi {{firstName}},</p>
      <p style="color: #555555; line-height: 1.6; margin: 0 0 24px 0;">Thanks for signing up! Your account is all set and ready to go.</p>

      <p style="color: #555555; line-height: 1.6; margin: 0 0 24px 0;">To get started, choose a subscription plan and you'll be checking in at the gym in no time.</p>

      {{> button url=loginUrl text="Get Started"}}
    </div>

    {{> footer}}
  </div>
</body>
</html>
