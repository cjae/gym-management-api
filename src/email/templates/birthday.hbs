<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f0f0f0;">
  <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff;">
    {{> header}}

    <div style="padding: 32px 24px; text-align: center;">
      <h2 style="color: #333333; margin: 0 0 16px 0;">Happy Birthday, {{firstName}}! 🎂</h2>
      <p style="color: #555555; line-height: 1.6; margin: 0 0 16px 0;">Wishing you a fantastic birthday filled with joy and great workouts!</p>
      <p style="color: #555555; line-height: 1.6; margin: 0 0 24px 0;">Thank you for being part of our gym family. Here's to another year of crushing your fitness goals!</p>
    </div>

    {{> footer}}
  </div>
</body>
</html>
